#!/bin/sh
set -eu

duration=${SYMPHONY_INSTANCE_DURATION:-3h}
machine_type=${SYMPHONY_MACHINE_TYPE:-linux/amd64:4x8}
volume_size=${SYMPHONY_VOLUME_SIZE:-150gb}
image=${SYMPHONY_IMAGE:?set SYMPHONY_IMAGE to the nscr.io image built by bin/build-image}
fnox_config=${SYMPHONY_FNOX_CONFIG:?set SYMPHONY_FNOX_CONFIG to the local fnox config containing LINEAR_API_KEY and OPENAI_API_KEY}

set -- \
  --bare \
  --duration "$duration" \
  --machine_type "$machine_type" \
  --purpose "Long-running OpenAI Symphony for Arrusted" \
  --unique_tag arrusted-symphony

if [ "${SYMPHONY_PERSISTENT_VOLUME:-false}" = true ]; then
  set -- "$@" --volume "persistent:arrusted-symphony:/workspaces:${volume_size}"
fi

instance_id=$(nsc create "$@" \
  --output json | jq -er '.instance_id // .id')

secret_file=$(mktemp "${TMPDIR:-/tmp}/symphony-secrets.XXXXXX")
trap 'rm -f "$secret_file"' EXIT HUP INT TERM
chmod 600 "$secret_file"

fnox exec --config "$fnox_config" -- sh -c 'printf "LINEAR_API_KEY=%s\nOPENAI_API_KEY=%s\n" "$LINEAR_API_KEY" "$OPENAI_API_KEY"' > "$secret_file"
printf 'GITHUB_TOKEN=%s\n' "$(gh auth token)" >> "$secret_file"

nsc instance upload "$instance_id" "$secret_file" /tmp/symphony.env
nsc ssh "$instance_id" --disable-pty -- sh -s -- "$image" <<'REMOTE'
set -eu
image=$1
install -m 600 /tmp/symphony.env /etc/symphony.env
rm -f /tmp/symphony.env
mkdir -p /workspaces
chown -R 1001:1001 /workspaces
docker pull "$image"
docker rm -f symphony 2>/dev/null || true
docker run -d \
  --name symphony \
  --restart unless-stopped \
  --env-file /etc/symphony.env \
  --mount type=bind,src=/workspaces,dst=/workspaces \
  --publish 4410:4410 \
  "$image"
REMOTE

printf '%s\n' "$instance_id"
