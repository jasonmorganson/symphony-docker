#!/bin/sh
set -eu

: "${LINEAR_SECRET_ID:?set LINEAR_SECRET_ID to the Namespace sec_ ID}"
: "${OPENAI_SECRET_ID:?set OPENAI_SECRET_ID to the Namespace sec_ ID}"

case "$LINEAR_SECRET_ID" in sec_*) ;; *) echo "LINEAR_SECRET_ID must be a Namespace sec_ ID" >&2; exit 1 ;; esac
linear_suffix=${LINEAR_SECRET_ID#sec_}
case "$linear_suffix" in
  ''|*[!a-z0-9]*) echo "LINEAR_SECRET_ID must be a Namespace sec_ ID" >&2; exit 1 ;;
esac

case "$OPENAI_SECRET_ID" in sec_*) ;; *) echo "OPENAI_SECRET_ID must be a Namespace sec_ ID" >&2; exit 1 ;; esac
openai_suffix=${OPENAI_SECRET_ID#sec_}
case "$openai_suffix" in
  ''|*[!a-z0-9]*) echo "OPENAI_SECRET_ID must be a Namespace sec_ ID" >&2; exit 1 ;;
esac

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_dir=$(dirname "$script_dir")

sed \
  -e "s/REPLACE_WITH_LINEAR_SECRET_ID/$LINEAR_SECRET_ID/" \
  -e "s/REPLACE_WITH_OPENAI_SECRET_ID/$OPENAI_SECRET_ID/" \
  "$repo_dir/devbox.yaml" \
  | devbox create --from_format yaml -
